cat > $Z/zctl <<'SH'
#!/usr/bin/env bash
case "$1" in
  pre)   /home/z/z/scripts_preflight.sh;;
  bak)   /home/z/z/scripts_backup_daily.sh;;
  sql)   /home/z/z/scripts_sqlite_maint.sh;;
  conf)  /home/z/z/scripts_validate_config.sh;;
  log)   sudo journalctl -u z.service -n 50 --no-pager;;
  *) echo "zctl pre|bak|sql|conf|log";;
esac
SH